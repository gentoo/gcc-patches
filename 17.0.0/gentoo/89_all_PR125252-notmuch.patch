--- a/gcc/c/c-typeck.cc
+++ b/gcc/c/c-typeck.cc
@@ -579,8 +579,9 @@ c_reconstruct_complex_type (tree type, tree bottom)
 
 /* Helper function for c_canonical_type.  Check whether FIELD
    contains a pointer to a structure or union with tag,
